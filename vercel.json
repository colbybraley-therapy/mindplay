{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/therapist-dashboard", "dest": "/therapist-dashboard.html" },
    { "src": "/signup", "dest": "/signup.html" },
    { "src": "/characters", "dest": "/characters.html" },
    { "src": "/journal", "dest": "/src/activities/practices/reflection-journal/client.html" }
  ]
}
